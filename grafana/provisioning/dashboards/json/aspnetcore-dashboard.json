{
  "dashboard": {
    "id": null,
    "title": "Satis Talep Yonetimi",
    "tags": ["aspnetcore"],
    "timezone": "browser",
    "panels": [
      {
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(http_server_request_duration_seconds_count[5m])",
            "legendFormat": "{{http_route}} {{http_request_method}}"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "title": "HTTP Request Duration (p95)",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_server_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "title": "Active HTTP Connections",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "http_server_active_requests",
            "legendFormat": "Active"
          }
        ],
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 }
      },
      {
        "title": "HTTP Error Rate (5xx)",
        "type": "timeseries",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])",
            "legendFormat": "5xx errors"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
      }
    ],
    "schemaVersion": 39,
    "version": 1
  },
  "overwrite": true
}
